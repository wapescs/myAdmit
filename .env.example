## MongoDB (Phase 2 — not used yet, JSON files are the active data source in Phase 1)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=myadmit

## Pagination (see src/config/pagination.config.ts)
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

## Rate limiting — in-memory, per-instance only (see src/api-middleware/rate-limiter.ts)
RATE_LIMIT_ANONYMOUS_WINDOW_MS=60000
RATE_LIMIT_ANONYMOUS_MAX=60
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=60000
RATE_LIMIT_AUTHENTICATED_MAX=300

## Response caching (ETag / Cache-Control on GET routes, see src/config/cache.config.ts)
CACHE_TTL_SECONDS=60

## CORS — comma-separated list of allowed origins (see src/config/cors.config.ts)
CORS_ALLOWED_ORIGINS=http://localhost:3000
